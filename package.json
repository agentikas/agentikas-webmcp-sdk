{
  "name": "@agentikas/webmcp-sdk",
  "version": "0.13.0",
  "description": "Agentikas WebMCP SDK — Make any website visible to AI agents",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./provider": "./src/provider.tsx",
    "./verticals/restaurant": "./src/verticals/restaurant/index.ts",
    "./verticals/blog": "./src/verticals/blog/index.ts"
  },
  "scripts": {
    "build": "esbuild src/loader.ts --bundle --minify --format=iife --outfile=dist/webmcp.js",
    "build:watch": "esbuild src/loader.ts --bundle --format=iife --outfile=dist/webmcp.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "src"
  ],
  "license": "MIT"
}
